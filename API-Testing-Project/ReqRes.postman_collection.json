          "response": []
        },
        {
          "name": "List single user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "    const responseData = pm.response.json();\r",
                  "    const userID = pm.environment.get(\"userID\");\r",
                  "\r",
                  "pm.test(\"Correct User Fetched\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(responseData.data.id).to.eql(userID);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "pm.test(\"Response has the required fields - id, email, first_name, last_name, and avatar\", function () {\r",
                  "\r",
                  "\r",
                  "    pm.expect(responseData).to.be.an('object');\r",
                  "\r",
                  "    pm.expect(responseData.data.id).to.exist;\r",
                  "    pm.expect(responseData.data.email).to.exist;\r",
                  "    pm.expect(responseData.data.first_name).to.exist;\r",
                  "    pm.expect(responseData.data.last_name).to.exist;\r",
                  "    pm.expect(responseData.data.avatar).to.exist;\r",
                  "\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Email is in a valid format\", function () {\r",
                  "\r",
                  "    const responseData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(responseData.data.email)\r",
                  "        .to.be.a('string')\r",
                  "        .and.to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/, \"Email should be in a valid format\");\r",
                  "\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Verify the Content-Type header is application/json\", function () {\r",
                  "\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
                  "        .to.include(\"application/json\");\r",
                  "\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomValue =Math.floor(Math.random()*12)+1;\r",
                  "\r",
                  "pm.environment.set(\"userID\", randomValue);\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
