        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Correct response value\", function () {\r",
                  "     pm.expect(jsonData.page).to.eql(1);\r",
                  "    pm.expect(jsonData.per_page).to.eql(6);\r",
                  "    pm.expect(jsonData.total).to.eql(12);\r",
                  "    pm.expect(jsonData.total_pages).to.eql(2);\r",
                  "    pm.expect(jsonData.data[0].id).to.eql(1);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check if a user with the first name 'George' exists\", function () {\r",
                  "    // Parse the response JSON\r",
                  "    const response = pm.response.json();\r",
                  "\r",
                  "    // Extract the data array\r",
                  "    const dataArray = response.data;\r",
                  "\r",
                  "    // Initialize a flag to check if 'George' exists\r",
                  "    let georgeExists = false;\r",
                  "\r",
                  "    // Loop through the data array\r",
                  "    for (let i = 0; i < dataArray.length; i++) {\r",
                  "        if (dataArray[i].first_name === \"George\") {\r",
                  "            georgeExists = true;\r",
                  "            break;\r",
                  "        }\r",
                  "    }\r",
                  "\r",
                  "    // Assert that 'George' exists\r",
                  "    pm.expect(georgeExists).to.be.true;\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "reqres_18c3d4d342ea4141a151dbc7504fb90e",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users?page=1",
              "host": [
                "{{base_url}}"
              ],
